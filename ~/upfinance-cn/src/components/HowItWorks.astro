---
---

<section class="bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    <h2 class="text-3xl lg:text-4xl font-bold text-center text-gray-900 mb-16">
      如何使用
    </h2>

    <!-- Personal Users Path -->
    <div class="mb-20">
      <h3 class="text-2xl font-semibold text-center text-navy mb-10">个人用户</h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">1</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">注册账号</h4>
          <p class="text-gray-600 text-sm mt-1">简单几步快速注册</p>
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:block absolute top-8 left-1/4 transform -translate-x-1/2 w-1/4">
          <svg class="text-gray-300" fill="none" viewBox="0 0 100 2" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
            <path d="M0 1 h100"/>
          </svg>
        </div>

        <!-- Step 2 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">2</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">微信/支付宝充值</h4>
          <p class="text-gray-600 text-sm mt-1">支持国内主流支付</p>
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:block absolute top-8 left-1/2 transform -translate-x-1/2 w-1/4">
          <svg class="text-gray-300" fill="none" viewBox="0 0 100 2" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
            <path d="M0 1 h100"/>
          </svg>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">3</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">选择 AI 服务</h4>
          <p class="text-gray-600 text-sm mt-1">按需选择所需模型</p>
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:block absolute top-8 left-3/4 transform -translate-x-1/2 w-1/4">
           <svg class="text-gray-300" fill="none" viewBox="0 0 100 2" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
            <path d="M0 1 h100"/>
          </svg>
        </div>

        <!-- Step 4 -->
        <div class="text-center">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">4</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">一键开通</h4>
          <p class="text-gray-600 text-sm mt-1">立即获得 API 权限</p>
        </div>
      </div>
    </div>

    <!-- Business Users Path -->
    <div>
      <h3 class="text-2xl font-semibold text-center text-navy mb-10">企业用户</h3>
       <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        <!-- Step 1 -->
        <div class="text-center bg-gray-50 rounded-xl p-6">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">1</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">企业认证</h4>
          <p class="text-gray-600 text-sm mt-1">提供企业资料完成认证</p>
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:block absolute top-1/2 -translate-y-4 left-1/4 transform -translate-x-1/2 w-1/4">
           <svg class="text-gray-300" fill="none" viewBox="0 0 100 2" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
            <path d="M0 1 h100"/>
          </svg>
        </div>

        <!-- Step 2 -->
        <div class="text-center bg-gray-50 rounded-xl p-6">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">2</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">对公转账</h4>
          <p class="text-gray-600 text-sm mt-1">安全合规的支付方式</p>
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:block absolute top-1/2 -translate-y-4 left-1/2 transform -translate-x-1/2 w-1/4">
          <svg class="text-gray-300" fill="none" viewBox="0 0 100 2" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
            <path d="M0 1 h100"/>
          </svg>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center bg-gray-50 rounded-xl p-6">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">3</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">批量开通</h4>
          <p class="text-gray-600 text-sm mt-1">一次性为团队成员开通</p>
        </div>
        
        <!-- Arrow -->
        <div class="hidden md:block absolute top-1/2 -translate-y-4 left-3/4 transform -translate-x-1/2 w-1/4">
          <svg class="text-gray-300" fill="none" viewBox="0 0 100 2" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
            <path d="M0 1 h100"/>
          </svg>
        </div>

        <!-- Step 4 -->
        <div class="text-center bg-gray-50 rounded-xl p-6">
          <div class="w-16 h-16 bg-cyan/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan">4</span>
          </div>
          <h4 class="font-semibold text-lg text-navy">统一管理</h4>
          <p class="text-gray-600 text-sm mt-1">统一查看用量和账单</p>
        </div>
      </div>
    </div>
  </div>
</section>
